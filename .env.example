# Local development uses SQLite. Production points at Neon Postgres.
# For local dev: DATABASE_URL="file:./prisma/dev.db" and provider="sqlite" in schema.
# For Neon prod: DATABASE_URL="postgresql://USER:PASS@HOST/db?sslmode=require" and provider="postgresql".
DATABASE_URL="file:./prisma/dev.db"

# Auth.js secret — generate with: openssl rand -base64 32
AUTH_SECRET="change-me-to-something-random"

# Initial admin user — seeded on first db push.
ADMIN_EMAIL="admin@finanztool.de"
ADMIN_PASSWORD="changeme123"

# Used in Auth.js callbacks.
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"
